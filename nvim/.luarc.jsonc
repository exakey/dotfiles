{
        "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
        "workspace.library": [
                "vim.env.RUNTIME",
                "${3rd}/luv/library",
                "$HOME/.config/nvim/",
                // "$HOME/.local/share/nvim/lazy/",
        ],
        "runtime.version": "LuaJIT",
        "hint.enable": false
}
